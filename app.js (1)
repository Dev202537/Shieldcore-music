function cleanTitle(title) {
    return title.replace(/\(.*?\)|\[.*?\]|Official Music Video|Official Video|Clip Officiel|ft\.|feat\./gi, '').replace(/&quot;/g, '"').replace(/&#39;/g, "'").replace(/&amp;/g, "&").trim();
}

